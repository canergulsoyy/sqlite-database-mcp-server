{
    "name": "database-mcp-server",
    "version": "1.0.0",
    "description": "MCP Server that provides database querying capabilities with LLM integration",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=18.18.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "client:dev": "tsx src/client/index.ts",
        "client:build": "tsc -p tsconfig.json --outDir dist-client",
        "client:start": "node dist/client/index.js",
        "test:client": "node test-client.js",
        "db:setup": "tsx src/database/setup.ts",
        "db:seed": "tsx src/database/seed.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.3.0",
        "dotenv": "^16.4.1",
        "openai": "^5.22.0",
        "readline": "^1.3.0",
        "sqlite": "^5.1.1",
        "sqlite3": "^5.1.7",
        "undici": "^7.15.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/sqlite3": "^3.1.11",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
    },
    "keywords": [
        "mcp",
        "database",
        "sqlite",
        "llm",
        "ai",
        "model-context-protocol"
    ],
    "author": "Caner Gülsoy",
    "license": "MIT"
}